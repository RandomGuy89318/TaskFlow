# Environment Variables Template
# Copy this file to .env and fill in your Supabase project values.
# Find these in your Supabase dashboard under: Settings → API

# ─── Supabase ─────────────────────────────────────────────────────────────────

# Your project URL (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose in the browser (required)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — keep this SECRET, never commit or expose to the browser (optional)
# Only needed for admin scripts (e.g. seed scripts, migrations run server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
